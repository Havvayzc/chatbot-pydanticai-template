# ── BPMN Pipeline — required API keys ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: override default models ─────────────────────────────────────────
# Generator (default: Claude Opus 4.6)
GENERATOR_MODEL=anthropic:claude-opus-4-6

# Judge (default: Gemini 2.5 Pro — update to gemini-3.1-pro when available)
JUDGE_MODEL=google-gla:gemini-2.5-pro

# ── Optional: pipeline behaviour ──────────────────────────────────────────────
# Max correction iterations before returning the best available model (default: 3)
MAX_ITERATIONS=3

# ── Existing chatbot settings (optional) ──────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
