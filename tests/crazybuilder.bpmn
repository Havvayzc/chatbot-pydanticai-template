<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN-Pipeline" exporterVersion="1.0">
  <bpmn2:collaboration id="Collaboration_1">
    <bpmn2:participant id="Participant_System" name="System" processRef="Process_System" />
    <bpmn2:participant id="Participant_Handwerker" name="Handwerker" processRef="Process_Handwerker" />
    <bpmn2:participant id="Participant_Bauleiter" name="Bauleiter" processRef="Process_Bauleiter" />
    <bpmn2:messageFlow id="MF_TriggerHandwerker" name="Trigger" sourceRef="Task_TriggerHandwerker" targetRef="Start_Handwerker" />
    <bpmn2:messageFlow id="MF_AufgabenlisteAbrufen" name="Aufgabenliste" sourceRef="Task_AufgabenlisteAbrufen" targetRef="Catch_AufgabenAnfrage" />
    <bpmn2:messageFlow id="MF_AenderungMelden" name="Planänderung" sourceRef="Task_AenderungMelden" targetRef="Catch_Aenderung" />
    <bpmn2:messageFlow id="MF_FortschrittMelden" name="Fortschrittsmeldung" sourceRef="Task_FortschrittEintragen" targetRef="Catch_Fortschritt" />
    <bpmn2:messageFlow id="MF_AbnahmeNachricht" name="Abnahme möglich" sourceRef="Task_AbnahmeNachricht" targetRef="Start_Bauleiter" />
    <bpmn2:messageFlow id="MF_Erinnerung" name="Erinnerung" sourceRef="Task_ErinnerungSenden" targetRef="Catch_Erinnerung" />
    <bpmn2:messageFlow id="MF_AlleAbgeschlossen" name="Alle Leistungen abgeschlossen" sourceRef="Task_BauleiterInformieren" targetRef="Catch_AlleAbgeschlossen" />
  </bpmn2:collaboration>
  <bpmn2:process id="Process_System" isExecutable="false">
    <bpmn2:startEvent id="Start_System" name="Auftrag gestartet">
      <bpmn2:outgoing>SF_S1</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:task id="Task_TriggerHandwerker" name="Handwerker triggern">
      <bpmn2:incoming>SF_S1</bpmn2:incoming>
      <bpmn2:outgoing>SF_S2</bpmn2:outgoing>
      <bpmn2:multiInstanceLoopCharacteristics />
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_S1" sourceRef="Start_System" targetRef="Task_TriggerHandwerker" />
    <bpmn2:eventBasedGateway id="EBG_Warten" name="Auf Meldung warten">
      <bpmn2:incoming>SF_S2</bpmn2:incoming>
      <bpmn2:incoming>SF_S_LoopBack</bpmn2:incoming>
      <bpmn2:outgoing>SF_S3a</bpmn2:outgoing>
      <bpmn2:outgoing>SF_S3b</bpmn2:outgoing>
      <bpmn2:outgoing>SF_S3c</bpmn2:outgoing>
    </bpmn2:eventBasedGateway>
    <bpmn2:sequenceFlow id="SF_S2" sourceRef="Task_TriggerHandwerker" targetRef="EBG_Warten" />
    <bpmn2:intermediateCatchEvent id="Catch_Aenderung" name="Planänderung eingegangen">
      <bpmn2:incoming>SF_S3a</bpmn2:incoming>
      <bpmn2:outgoing>SF_S4a</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_Aenderung" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:sequenceFlow id="SF_S3a" sourceRef="EBG_Warten" targetRef="Catch_Aenderung" />
    <bpmn2:task id="Task_AufgabenAktualisieren" name="Aufgaben und Plandaten aktualisieren">
      <bpmn2:incoming>SF_S4a</bpmn2:incoming>
      <bpmn2:outgoing>SF_S5a</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_S4a" sourceRef="Catch_Aenderung" targetRef="Task_AufgabenAktualisieren" />
    <bpmn2:sequenceFlow id="SF_S5a" sourceRef="Task_AufgabenAktualisieren" targetRef="XOR_MergeBack" />
    <bpmn2:intermediateCatchEvent id="Catch_Fortschritt" name="Fortschrittsmeldung eingegangen">
      <bpmn2:incoming>SF_S3b</bpmn2:incoming>
      <bpmn2:outgoing>SF_S4b</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_Fortschritt" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:sequenceFlow id="SF_S3b" sourceRef="EBG_Warten" targetRef="Catch_Fortschritt" />
    <bpmn2:task id="Task_FortschrittAnalysieren" name="Fortschritt analysieren">
      <bpmn2:incoming>SF_S4b</bpmn2:incoming>
      <bpmn2:outgoing>SF_S5b</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_S4b" sourceRef="Catch_Fortschritt" targetRef="Task_FortschrittAnalysieren" />
    <bpmn2:exclusiveGateway id="XOR_AlleAufgaben" name="Alle Aufgaben erledigt?">
      <bpmn2:incoming>SF_S5b</bpmn2:incoming>
      <bpmn2:outgoing>SF_S6_ja</bpmn2:outgoing>
      <bpmn2:outgoing>SF_S6_nein</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_S5b" sourceRef="Task_FortschrittAnalysieren" targetRef="XOR_AlleAufgaben" />
    <bpmn2:task id="Task_AbnahmeNachricht" name="Abnahmenachricht senden">
      <bpmn2:incoming>SF_S6_ja</bpmn2:incoming>
      <bpmn2:outgoing>SF_S7</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_S6_ja" name="Ja" sourceRef="XOR_AlleAufgaben" targetRef="Task_AbnahmeNachricht" />
    <bpmn2:sequenceFlow id="SF_S6_nein" name="Nein" sourceRef="XOR_AlleAufgaben" targetRef="XOR_MergeBack" />
    <bpmn2:exclusiveGateway id="XOR_MergeBack">
      <bpmn2:incoming>SF_S5a</bpmn2:incoming>
      <bpmn2:incoming>SF_S6_nein</bpmn2:incoming>
      <bpmn2:incoming>SF_S_TimerDone</bpmn2:incoming>
      <bpmn2:outgoing>SF_S_LoopBack</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_S_LoopBack" sourceRef="XOR_MergeBack" targetRef="EBG_Warten" />
    <bpmn2:intermediateCatchEvent id="Catch_Deadline" name="Deadline erreicht">
      <bpmn2:incoming>SF_S3c</bpmn2:incoming>
      <bpmn2:outgoing>SF_S4c</bpmn2:outgoing>
      <bpmn2:timerEventDefinition id="TED_Deadline" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:sequenceFlow id="SF_S3c" sourceRef="EBG_Warten" targetRef="Catch_Deadline" />
    <bpmn2:task id="Task_ErinnerungSenden" name="Erinnerung an Handwerker senden">
      <bpmn2:incoming>SF_S4c</bpmn2:incoming>
      <bpmn2:outgoing>SF_S_TimerDone</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_S4c" sourceRef="Catch_Deadline" targetRef="Task_ErinnerungSenden" />
    <bpmn2:sequenceFlow id="SF_S_TimerDone" sourceRef="Task_ErinnerungSenden" targetRef="XOR_MergeBack" />
    <bpmn2:intermediateCatchEvent id="Catch_AufgabenAnfrage" name="Aufgabenlistenanfrage eingegangen">
      <bpmn2:messageEventDefinition id="MED_AufgabenAnfrage" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:exclusiveGateway id="XOR_AlleHandwerker" name="Alle Handwerkerleistungen abgeschlossen?">
      <bpmn2:incoming>SF_S7</bpmn2:incoming>
      <bpmn2:outgoing>SF_S8_ja</bpmn2:outgoing>
      <bpmn2:outgoing>SF_S8_nein</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_S7" sourceRef="Task_AbnahmeNachricht" targetRef="XOR_AlleHandwerker" />
    <bpmn2:endEvent id="End_System_Einzel" name="Handwerkerauftrag erledigt">
      <bpmn2:incoming>SF_S8_nein</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="SF_S8_nein" name="Nein" sourceRef="XOR_AlleHandwerker" targetRef="End_System_Einzel" />
    <bpmn2:task id="Task_BauleiterInformieren" name="Bauleiter informieren">
      <bpmn2:incoming>SF_S8_ja</bpmn2:incoming>
      <bpmn2:outgoing>SF_S9</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_S8_ja" name="Ja" sourceRef="XOR_AlleHandwerker" targetRef="Task_BauleiterInformieren" />
    <bpmn2:endEvent id="End_System_Alle" name="Alle Aufträge abgeschlossen">
      <bpmn2:incoming>SF_S9</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="SF_S9" sourceRef="Task_BauleiterInformieren" targetRef="End_System_Alle" />
  </bpmn2:process>
  <bpmn2:process id="Process_Handwerker" isExecutable="false">
    <bpmn2:startEvent id="Start_Handwerker" name="Vom System getriggert">
      <bpmn2:outgoing>SF_H1</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_StartHW" />
    </bpmn2:startEvent>
    <bpmn2:task id="Task_EinsatzVorbereiten" name="Einsatz vorbereiten">
      <bpmn2:incoming>SF_H1</bpmn2:incoming>
      <bpmn2:outgoing>SF_H2</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_H1" sourceRef="Start_Handwerker" targetRef="Task_EinsatzVorbereiten" />
    <bpmn2:task id="Task_AufgabenlisteAbrufen" name="Aufgabenliste abrufen">
      <bpmn2:incoming>SF_H2</bpmn2:incoming>
      <bpmn2:incoming>SF_H_LoopBack</bpmn2:incoming>
      <bpmn2:outgoing>SF_H3</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_H2" sourceRef="Task_EinsatzVorbereiten" targetRef="Task_AufgabenlisteAbrufen" />
    <bpmn2:task id="Task_AufgabenErledigen" name="Aufgaben erledigen">
      <bpmn2:incoming>SF_H3</bpmn2:incoming>
      <bpmn2:outgoing>SF_H4</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_H3" sourceRef="Task_AufgabenlisteAbrufen" targetRef="Task_AufgabenErledigen" />
    <bpmn2:exclusiveGateway id="XOR_Aenderung" name="Planänderung nötig?">
      <bpmn2:incoming>SF_H4</bpmn2:incoming>
      <bpmn2:outgoing>SF_H5_ja</bpmn2:outgoing>
      <bpmn2:outgoing>SF_H5_nein</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_H4" sourceRef="Task_AufgabenErledigen" targetRef="XOR_Aenderung" />
    <bpmn2:task id="Task_AenderungMelden" name="Planänderung melden">
      <bpmn2:incoming>SF_H5_ja</bpmn2:incoming>
      <bpmn2:outgoing>SF_H6</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_H5_ja" name="Ja" sourceRef="XOR_Aenderung" targetRef="Task_AenderungMelden" />
    <bpmn2:exclusiveGateway id="XOR_MergeAenderung">
      <bpmn2:incoming>SF_H6</bpmn2:incoming>
      <bpmn2:incoming>SF_H5_nein</bpmn2:incoming>
      <bpmn2:outgoing>SF_H7</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_H5_nein" name="Nein" sourceRef="XOR_Aenderung" targetRef="XOR_MergeAenderung" />
    <bpmn2:sequenceFlow id="SF_H6" sourceRef="Task_AenderungMelden" targetRef="XOR_MergeAenderung" />
    <bpmn2:task id="Task_FortschrittEintragen" name="Fortschritt eintragen">
      <bpmn2:incoming>SF_H7</bpmn2:incoming>
      <bpmn2:outgoing>SF_H8</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_H7" sourceRef="XOR_MergeAenderung" targetRef="Task_FortschrittEintragen" />
    <bpmn2:exclusiveGateway id="XOR_Abnahmebereit" name="Auftrag zur Abnahme bereit?">
      <bpmn2:incoming>SF_H8</bpmn2:incoming>
      <bpmn2:outgoing>SF_H9_nein</bpmn2:outgoing>
      <bpmn2:outgoing>SF_H9_ja</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_H8" sourceRef="Task_FortschrittEintragen" targetRef="XOR_Abnahmebereit" />
    <bpmn2:sequenceFlow id="SF_H9_nein" name="Nein" sourceRef="XOR_Abnahmebereit" targetRef="XOR_ErinnerungMerge" />
    <bpmn2:exclusiveGateway id="XOR_ErinnerungMerge">
      <bpmn2:incoming>SF_H9_nein</bpmn2:incoming>
      <bpmn2:incoming>SF_H_ErinnerungDone</bpmn2:incoming>
      <bpmn2:outgoing>SF_H_LoopBack</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:sequenceFlow id="SF_H_LoopBack" sourceRef="XOR_ErinnerungMerge" targetRef="Task_AufgabenlisteAbrufen" />
    <bpmn2:intermediateCatchEvent id="Catch_Erinnerung" name="Erinnerung erhalten">
      <bpmn2:outgoing>SF_H_ErinnerungDone</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_Erinnerung" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:sequenceFlow id="SF_H_ErinnerungDone" sourceRef="Catch_Erinnerung" targetRef="XOR_ErinnerungMerge" />
    <bpmn2:endEvent id="End_Handwerker" name="Auftrag abgeschlossen">
      <bpmn2:incoming>SF_H9_ja</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="SF_H9_ja" name="Ja" sourceRef="XOR_Abnahmebereit" targetRef="End_Handwerker" />
  </bpmn2:process>
  <bpmn2:process id="Process_Bauleiter" isExecutable="false">
    <bpmn2:startEvent id="Start_Bauleiter" name="Abnahmenachricht eingegangen">
      <bpmn2:outgoing>SF_B1</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_StartBL" />
    </bpmn2:startEvent>
    <bpmn2:task id="Task_AbnahmeDurchfuehren" name="Abnahme durchführen">
      <bpmn2:incoming>SF_B1</bpmn2:incoming>
      <bpmn2:outgoing>SF_B2</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_B1" sourceRef="Start_Bauleiter" targetRef="Task_AbnahmeDurchfuehren" />
    <bpmn2:eventBasedGateway id="EBG_Bauleiter" name="Auf weitere Nachricht warten">
      <bpmn2:incoming>SF_B2</bpmn2:incoming>
      <bpmn2:outgoing>SF_B3a</bpmn2:outgoing>
      <bpmn2:outgoing>SF_B3b</bpmn2:outgoing>
    </bpmn2:eventBasedGateway>
    <bpmn2:sequenceFlow id="SF_B2" sourceRef="Task_AbnahmeDurchfuehren" targetRef="EBG_Bauleiter" />
    <bpmn2:intermediateCatchEvent id="Catch_AlleAbgeschlossen" name="Alle Leistungen abgeschlossen">
      <bpmn2:incoming>SF_B3a</bpmn2:incoming>
      <bpmn2:outgoing>SF_B4a</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_AlleAbgeschlossen" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:sequenceFlow id="SF_B3a" sourceRef="EBG_Bauleiter" targetRef="Catch_AlleAbgeschlossen" />
    <bpmn2:endEvent id="End_Bauleiter_Alle" name="Gesamtprojekt abgeschlossen">
      <bpmn2:incoming>SF_B4a</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="SF_B4a" sourceRef="Catch_AlleAbgeschlossen" targetRef="End_Bauleiter_Alle" />
    <bpmn2:intermediateCatchEvent id="Catch_WeitereAbnahme" name="Weitere Abnahmenachricht eingegangen">
      <bpmn2:incoming>SF_B3b</bpmn2:incoming>
      <bpmn2:outgoing>SF_B4b</bpmn2:outgoing>
      <bpmn2:messageEventDefinition id="MED_WeitereAbnahme" />
    </bpmn2:intermediateCatchEvent>
    <bpmn2:sequenceFlow id="SF_B3b" sourceRef="EBG_Bauleiter" targetRef="Catch_WeitereAbnahme" />
    <bpmn2:task id="Task_WeitereAbnahme" name="Abnahme durchführen">
      <bpmn2:incoming>SF_B4b</bpmn2:incoming>
      <bpmn2:outgoing>SF_B5</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="SF_B4b" sourceRef="Catch_WeitereAbnahme" targetRef="Task_WeitereAbnahme" />
    <bpmn2:sequenceFlow id="SF_B5" sourceRef="Task_WeitereAbnahme" targetRef="EBG_Bauleiter" />
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
